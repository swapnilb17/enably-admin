# Server-only env vars. Never expose any of these to the browser.

# Existing FastAPI base URL (without trailing slash). The admin app calls
# only /internal/admin/* on this host; it never touches user-facing routes.
BACKEND_URL=https://api.example.com

# Shared secret sent as `x-internal-api-key` when calling /internal/admin/* on
# FastAPI. Reuses the existing INTERNAL_API_SECRET on the FastAPI side
# (see EnablyAI_VGEN/backend/app/main.py::_require_internal_api_key).
INTERNAL_API_SECRET=change-me-long-random-string

# Comma-separated list of allowed admin emails (Phase 2 OAuth) or a single
# admin password for Phase 1 cookie login.
ADMIN_PASSWORD=change-me-strong-password
ADMIN_ALLOWLIST_EMAILS=ops@enably.ai,founder@enably.ai

# Used to sign the session cookie. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-base64-48-bytes

# Optional: cookie name + max age (seconds). Default 8h.
SESSION_COOKIE_NAME=enably_admin_session
SESSION_MAX_AGE=28800

# Optional: how long (seconds) cached admin reads stay fresh before the BFF
# re-fetches from FastAPI. Higher = less load on the existing app server.
ADMIN_CACHE_TTL=60

# In production set to true (HTTPS only). Set to false when serving on
# plain HTTP during initial bring-up.
SESSION_COOKIE_SECURE=true
