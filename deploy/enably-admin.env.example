## /etc/enably-admin.env
## Mode: 0640, owned by root:ec2-user (so the service can read it).
NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# Existing FastAPI base URL (no trailing slash). Use the *private* IP of the
# existing EnablyAI_VGEN EC2 if both instances live in the same VPC, so
# traffic stays on the AWS internal network.
BACKEND_URL=http://10.0.0.0:8000
# Same value as INTERNAL_API_SECRET on FastAPI (sent as x-internal-api-key).
INTERNAL_API_SECRET=change-me-long-random-string
ADMIN_PASSWORD=change-me-strong-password
ADMIN_ALLOWLIST_EMAILS=ops@enably.ai
SESSION_SECRET=change-me-base64-48-bytes
SESSION_COOKIE_NAME=enably_admin_session
SESSION_MAX_AGE=28800
ADMIN_CACHE_TTL=60

# Set to "false" while serving over plain HTTP during initial bring-up.
# Flip back to "true" once HTTPS is configured.
SESSION_COOKIE_SECURE=true
