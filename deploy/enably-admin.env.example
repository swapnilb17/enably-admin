## /etc/enably-admin.env
## Mode: 0640, owned by root:ubuntu (so the service can read it).
NODE_ENV=production
PORT=3000
HOST=127.0.0.1

BACKEND_URL=https://api.example.com
ADMIN_API_KEY=change-me-long-random-string
ADMIN_PASSWORD=change-me-strong-password
ADMIN_ALLOWLIST_EMAILS=ops@enably.ai
SESSION_SECRET=change-me-base64-48-bytes
SESSION_COOKIE_NAME=enably_admin_session
SESSION_MAX_AGE=28800
ADMIN_CACHE_TTL=60

# Set to "false" while serving over plain HTTP during initial bring-up.
# Flip back to "true" once HTTPS is configured.
SESSION_COOKIE_SECURE=true
